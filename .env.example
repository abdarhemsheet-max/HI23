# انسخ هذا الملف باسم .env واملأ القيم بعد إنشاء مشروع Supabase وحاوية B2
# (راجع قسم "الإعداد السحابي" في README.md للتفاصيل خطوة بخطوة)

# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Backblaze B2 → App Keys (Application Key مقيّد بحاوية واحدة فقط — مستحسن)
VITE_B2_KEY_ID=
VITE_B2_APPLICATION_KEY=
VITE_B2_BUCKET_ID=
VITE_B2_BUCKET_NAME=
